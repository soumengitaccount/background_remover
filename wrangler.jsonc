{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "backgroundremover",
  "compatibility_date": "2026-07-15",
  "main": "./dist/_worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
